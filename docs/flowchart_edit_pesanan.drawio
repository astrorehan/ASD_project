          <mxGeometry x="400" y="740" width="150" height="35" as="geometry" />
        </mxCell>

        <!-- Tampilkan Enum Layanan -->
        <mxCell id="s9" value="Tampilkan Opsi Jenis Layanan&#xa;&#xa;0 = Tidak berubah&#xa;1 = Regular&#xa;2 = Deep Cleaning&#xa;3 = Repair&#xa;4 = Repaint&#xa;5 = Whitening" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="620" y="610" width="180" height="110" as="geometry" />
