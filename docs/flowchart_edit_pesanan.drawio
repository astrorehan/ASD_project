          <mxGeometry x="640" y="740" width="140" height="35" as="geometry" />
        </mxCell>

        <!-- Update -->
        <mxCell id="s11" value="target.namaPelanggan = namaBaru&#xa;target.jenisSepatu = enum(sepatu)&#xa;target.jenisLayanan = enum(layanan)&#xa;target.durasiLayananMenit =&#xa;  DurasiStandar(layanan)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="370" y="800" width="260" height="70" as="geometry" />
