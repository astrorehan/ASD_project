<mxfile host="app.diagrams.net" modified="2026-04-10T00:00:00.000Z" agent="Claude" version="24.0.0">
  <diagram name="Edit Pesanan" id="edit-pesanan">
    <mxGraphModel dx="1000" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1000" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- START -->
        <mxCell id="s1" value="START&#xa;Edit Pesanan" style="ellipse;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="440" y="10" width="120" height="40" as="geometry" />
        </mxCell>

        <!-- Tampilkan Antrean -->
        <mxCell id="s2" value="Tampilkan semua&#xa;pesanan di antrean" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="400" y="70" width="200" height="45" as="geometry" />
        </mxCell>

        <!-- Input Index -->
        <mxCell id="s3" value="Input nomor&#xa;pesanan yang ingin diedit" style="shape=parallelogram;perimeter=parallelogramPerimeter;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="400" y="140" width="200" height="50" as="geometry" />
        </mxCell>

        <!-- Decision Batal? -->
        <mxCell id="d0" value="nomor == 0?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="450" y="215" width="100" height="60" as="geometry" />
        </mxCell>

        <!-- Batal -->
        <mxCell id="batal" value="Kembali ke Menu" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="590" y="225" width="130" height="35" as="geometry" />
        </mxCell>

        <!-- getAt -->
        <mxCell id="s4" value="target = antrean.getAt(index)&#xa;(index = nomor - 1)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="400" y="300" width="200" height="45" as="geometry" />
        </mxCell>

        <!-- Decision Valid? -->
        <mxCell id="d1" value="target == NULL?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="430" y="370" width="140" height="65" as="geometry" />
        </mxCell>

        <!-- Invalid -->
        <mxCell id="inv" value="Tampilkan&#xa;'Index Tidak Valid'" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="600" y="380" width="140" height="45" as="geometry" />
        </mxCell>

        <!-- Tampilkan Data Lama -->
        <mxCell id="s5" value="Tampilkan data lama&#xa;(nama, jenis sepatu,&#xa;jenis layanan)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="400" y="460" width="200" height="55" as="geometry" />
        </mxCell>

        <!-- Input Nama Baru -->
        <mxCell id="s6" value="Input nama baru&#xa;(Enter = tidak berubah)" style="shape=parallelogram;perimeter=parallelogramPerimeter;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="400" y="540" width="200" height="50" as="geometry" />
        </mxCell>

        <!-- Tampilkan Enum Sepatu -->
        <mxCell id="s7" value="Tampilkan Opsi Jenis Sepatu&#xa;&#xa;0 = Tidak berubah&#xa;1 = Sneakers&#xa;2 = Boots&#xa;3 = Sandals&#xa;4 = Formal&#xa;5 = Olahraga" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="370" y="610" width="200" height="110" as="geometry" />
        </mxCell>

        <!-- Input Pilih Sepatu -->
