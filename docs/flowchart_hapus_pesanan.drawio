<mxfile host="app.diagrams.net" modified="2026-04-10T00:00:00.000Z" agent="Claude" version="24.0.0">
  <diagram name="Hapus Pesanan" id="hapus-pesanan">
    <mxGraphModel dx="900" dy="600" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="900" pageHeight="600" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- START -->
        <mxCell id="s1" value="START&#xa;Hapus Pesanan" style="ellipse;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="395" y="10" width="110" height="40" as="geometry" />
        </mxCell>

        <!-- Tampilkan Antrean -->
        <mxCell id="s2" value="Tampilkan semua&#xa;pesanan di antrean" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="340" y="70" width="220" height="45" as="geometry" />
        </mxCell>

        <!-- Input Index -->
        <mxCell id="s3" value="Input nomor&#xa;pesanan yang ingin dihapus" style="shape=parallelogram;perimeter=parallelogramPerimeter;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="340" y="140" width="220" height="50" as="geometry" />
        </mxCell>

        <!-- Decision Batal? -->
        <mxCell id="d0" value="nomor == 0?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="400" y="215" width="100" height="60" as="geometry" />
        </mxCell>

        <!-- Batal -->
        <mxCell id="batal" value="Kembali ke Menu" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="540" y="225" width="130" height="35" as="geometry" />
        </mxCell>

        <!-- Konfirmasi -->
        <mxCell id="s4" value="Tampilkan Konfirmasi&#xa;&#xa;Hapus pesanan #nomor?&#xa;&#xa;Enter = Ya&#xa;0 = Batal" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="310" y="300" width="280" height="80" as="geometry" />
        </mxCell>

        <!-- Input Konfirmasi -->
        <mxCell id="s5" value="Input konfirmasi" style="shape=parallelogram;perimeter=parallelogramPerimeter;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="360" y="405" width="140" height="35" as="geometry" />
        </mxCell>

        <!-- Decision Ya? -->
        <mxCell id="d1" value="konfirmasi ==&#xa;'' (Enter)?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="390" y="460" width="120" height="70" as="geometry" />
        </mxCell>

        <!-- Batal 2 -->
        <mxCell id="batal2" value="Dibatalkan" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="560" y="475" width="100" height="35" as="geometry" />
        </mxCell>

        <!-- removeAt -->
        <mxCell id="s6" value="antrean.removeAt(index)&#xa;(index = nomor - 1)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="340" y="555" width="200" height="45" as="geometry" />
        </mxCell>

        <!-- Recalculate -->
        <mxCell id="s7" value="antrean.calculateTime()&#xa;(update estimasi&#xa;semua pesanan)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="330" y="620" width="220" height="50" as="geometry" />
        </mxCell>

        <!-- Sukses -->
        <mxCell id="s8" value="Tampilkan&#xa;'Pesanan Dihapus'" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="355" y="695" width="150" height="40" as="geometry" />
        </mxCell>

        <!-- END -->
        <mxCell id="end" value="END" style="ellipse;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="395" y="755" width="90" height="30" as="geometry" />
        </mxCell>

        <!-- Note box -->
        <mxCell id="note" value="removeAt Logic:&#xa;&#xa;Index == 0 (head):&#xa;  front = front.next&#xa;  if empty: rear = NULL&#xa;&#xa;Index > 0 (middle/tail):&#xa;  prev = front&#xa;  for i < index-1: prev = prev.next&#xa;  target = prev.next&#xa;  prev.next = target.next&#xa;  if target == rear:&#xa;    rear = prev" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999999;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="580" y="540" width="220" height="140" as="geometry" />
        </mxCell>

